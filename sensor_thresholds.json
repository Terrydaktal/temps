{
  "version": 1,
  "description": "Fallback temperature warn/crit thresholds. Real reported sensor limits win when available.",
  "overrides": [
    {
      "name": "AMD Ryzen 9 9950X package and CCD temps",
      "device_regex": "^AMD Ryzen 9 9950X\\b",
      "sensor_regex": "^(Tctl|Tccd\\d+)$",
      "warn": 85.0,
      "crit": 95.0,
      "prefer_reported": true
    },
    {
      "name": "WD_BLACK SN8100 NVMe",
      "device_regex": "^WD_BLACK SN8100\\b",
      "sensor_regex": "^Composite$",
      "warn": 75.0,
      "crit": 85.0,
      "prefer_reported": true
    },
    {
      "name": "WD_BLACK SN8100 NAND (Sensor 2)",
      "device_regex": "^WD_BLACK SN8100\\b",
      "sensor_regex": "^Sensor 2$",
      "warn": 75.0,
      "crit": 85.0,
      "prefer_reported": true
    },
    {
      "name": "WD_BLACK SN8100 Controller (Sensor 1)",
      "device_regex": "^WD_BLACK SN8100\\b",
      "sensor_regex": "^Sensor 1$",
      "warn": 75.0,
      "crit": 85.0,
      "prefer_reported": true
    },
    {
      "name": "nct6686 Chipset",
      "device_regex": "^nct6686$",
      "sensor_regex": "^Chipset Temperature$",
      "warn": 75.0,
      "crit": 90.0,
      "prefer_reported": true
    },
    {
      "name": "nct6686 VRM",
      "device_regex": "^nct6686$",
      "sensor_regex": "^VRM Temperature$",
      "warn": 85.0,
      "crit": 100.0,
      "prefer_reported": true
    },
    {
      "name": "DDR5 DIMM Thermistor (fallback only)",
      "device_regex": "^DIMM Thermistor \\(SPD5118\\)$",
      "sensor_regex": "^temp1$",
      "warn": 60.0,
      "crit": 85.0,
      "prefer_reported": true
    },
    {
      "name": "Realtek Ethernet Controller",
      "device_regex": "^Realtek Ethernet Controller$",
      "sensor_regex": "^temp1$",
      "warn": 85.0,
      "crit": 100.0,
      "prefer_reported": false
    },
    {
      "name": "MediaTek MT7921 Wi-Fi",
      "device_regex": "^MediaTek MT7921 Wi-Fi$",
      "sensor_regex": "^temp1$",
      "warn": 70.0,
      "crit": 85.0,
      "prefer_reported": true
    },
    {
      "name": "nct6686 System Temperature",
      "device_regex": "^nct6686$",
      "sensor_regex": "^System Temperature$",
      "warn": 65.0,
      "crit": 80.0,
      "prefer_reported": true
    },
    {
      "name": "nct6686 CPU Temperature (socket)",
      "device_regex": "^nct6686$",
      "sensor_regex": "^CPU Temperature$",
      "warn": 80.0,
      "crit": 90.0,
      "prefer_reported": true
    },
    {
      "name": "NVIDIA GeForce RTX 5060",
      "device_regex": "^(NVIDIA\\s+)?GeForce\\s+RTX\\s+5060\\b",
      "sensor_regex": "^GPU (Core|Memory)$",
      "warn": 83.0,
      "crit": 90.0,
      "prefer_reported": true
    }
  ]
}
